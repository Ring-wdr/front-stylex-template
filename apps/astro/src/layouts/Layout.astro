---
interface Props {
  title: string;
}

const { title } = Astro.props;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {isDev && <script is:inline type="module" src="/@id/virtual:stylex:runtime"></script>}
    {isDev && <link rel="stylesheet" href="/virtual:stylex.css" />}
    <style>
      :global(*) {
        box-sizing: border-box;
      }
      :global(html, body) {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }
      :global(body) {
        min-height: 100vh;
      }
      :global(a) {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
